{
  "name": "@navegante/form-2307-sdk",
  "version": "0.1.0",
  "description": "Typed validation and deterministic PDF overlay rendering for BIR Form 2307 (January 2018 ENCS v3)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "sync-layout": "node ../../scripts/sync-layout.mjs",
    "prebuild": "npm run sync-layout",
    "pretypecheck": "npm run sync-layout",
    "pretest": "npm run sync-layout",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "example": "tsx ../../examples/generate.ts"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {"node": ">=20"},
  "license": "FSL-1.1-ALv2"
}
